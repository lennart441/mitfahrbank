# PostgreSQL
POSTGRES_USER=mitfahrbank
POSTGRES_PASSWORD=change-me
POSTGRES_DB=mitfahrbank
DATABASE_URL=postgres://mitfahrbank:change-me@db:5432/mitfahrbank

# App
NODE_ENV=production
PORT=3000
SESSION_SECRET=generate-at-least-32-random-characters-here
PUBLIC_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# Authentik OIDC (https://goauthentik.io/docs/providers/oauth2/)
OIDC_ISSUER=https://authentik.example.com/application/o/mitfahrbank/
OIDC_CLIENT_ID=mitfahrbank
OIDC_CLIENT_SECRET=your-client-secret
OIDC_REDIRECT_URI=http://localhost:3000/auth/callback

# Karte (Holstein – Zentrum)
MAP_DEFAULT_LAT=54.05
MAP_DEFAULT_LON=10.3
MAP_DEFAULT_ZOOM=11

# Web Push (VAPID) — Schlüssel erzeugen: cd backend && node --input-type=module -e "import w from 'web-push'; console.log(w.generateVAPIDKeys())"
WEB_PUSH_ENABLED=true
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:mitfahrbank@ihre-gemeinde.de
