{
  "name": "mitfahrbank-web",
  "version": "1.0.2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "build:android": "vite build && cap sync android",
    "android:open": "cap open android",
    "android:run": "cap run android",
    "build:ios": "LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 vite build && LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 cap sync ios",
    "ios:open": "cap open ios",
    "ios:archive": "npm run build:ios && node scripts/ios-archive.mjs",
    "ios:export": "node scripts/ios-export.mjs",
    "ios:upload": "npm run ios:archive && npm run ios:export"
  },
  "dependencies": {
    "@capacitor-firebase/messaging": "^7.2.0",
    "@capacitor/android": "^7.2.0",
    "@capacitor/ios": "^7.2.0",
    "@capacitor/app": "^7.0.1",
    "@capacitor/browser": "^7.0.1",
    "@capacitor/core": "^7.2.0",
    "@capacitor/network": "^7.0.1",
    "@capacitor/push-notifications": "^7.0.1",
    "firebase": "^11.6.0",
    "leaflet": "^1.9.4",
    "workbox-precaching": "^7.4.1",
    "workbox-routing": "^7.4.1",
    "workbox-window": "^7.4.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.2.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@types/leaflet": "^1.9.21",
    "@vite-pwa/assets-generator": "^0.2.6",
    "svelte": "^5.20.5",
    "typescript": "^6.0.3",
    "vite": "^6.2.2",
    "vite-plugin-pwa": "^0.21.1"
  }
}
